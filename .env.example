# === Interview Prep Pipeline Config ===
# Values with spaces MUST be quoted for shell sourcing to work.

# OpenAI API key (required)
OPENAI_API_KEY=sk-...

# Model (default: gpt-5.2-pro). Uses OpenAI Responses API.
OPENAI_MODEL=gpt-5.2-pro

# Reasoning effort: xhigh | high | medium | low (default: xhigh)
OPENAI_EFFORT=xhigh

# OPENAI_VERBOSITY=""                    # text verbosity (high/medium/none) — auto-detected from model if unset

# Max output tokens (default: 16000)
OPENAI_MAX_TOKENS=16000

# Freshness date for frontier digests (default: Feb 2026)
AS_OF_DATE="Feb 2026"

# === Target Role (customize for your interview prep) ===

PREP_ROLE="Staff Engineer"
PREP_COMPANY="a top tech company"
PREP_DOMAIN="Security & Infrastructure"
PREP_AUDIENCE="Senior Software Engineers"

# === Episode Counts (optional — profile config overrides these) ===

# PREP_CORE_EPISODES=12                   # Number of core episodes (default: 12)
# PREP_FRONTIER_EPISODES=3                # Number of frontier episodes (default: 3)
